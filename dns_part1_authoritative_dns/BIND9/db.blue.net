;
; BIND9 forward data file for blue.net.
;
$TTL    86400
$ORIGIN blue.net.
@       IN      SOA     ns1.red.net. hostmaster.red.net. (
                              1         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                          86400 )       ; Negative Cache TTL
;
@       IN      NS      ns1.red.net.
pc1     IN      A       192.168.5.101
pc2     IN      A       192.168.5.102
pc3     IN      A       192.168.5.103
