;
; BIND9 reverse data file for red.net.
;
$TTL    86400
$ORIGIN 80.30.89.in-addr.arpa.
@       IN      SOA     ns1.red.net. hostmaster.red.net. (
                              1         ; Serial
                         604800         ; Refresh
                          86400         ; Retry
                        2419200         ; Expire
                          86400 )       ; Negative Cache TTL
;
@       IN      NS      ns1.red.net.
35      IN      PTR     ns1.red.net.
